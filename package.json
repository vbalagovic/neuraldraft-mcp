{
  "name": "@neuraldraft/mcp",
  "version": "0.2.0",
  "description": "MCP server exposing Neural Draft's content/blog/social/booking/commerce APIs to AI coding tools (Claude Code, Cursor, Continue, etc.).",
  "type": "module",
  "bin": {
    "neuraldraft-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "ai",
    "claude",
    "claude-code",
    "cursor",
    "continue",
    "cms",
    "blog",
    "neural-draft",
    "lovable",
    "v0",
    "bolt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbalagovic/neuraldraft-mcp.git"
  },
  "homepage": "https://github.com/vbalagovic/neuraldraft-mcp#readme",
  "bugs": {
    "url": "https://github.com/vbalagovic/neuraldraft-mcp/issues"
  },
  "author": "Neural Draft <developers@neuraldraft.io>",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nock": "^14.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.4.0"
  }
}
